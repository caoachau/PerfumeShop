# Copy this file to `.env` in the same folder (`server/.env`).
# Run from repo root: copy server\.env.example server\.env

NODE_ENV=development
PORT=5000

# Local: mongodb://127.0.0.1:27017/parfum-shop
# Atlas: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/parfum-shop?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/parfum-shop

# Generate strong random strings (>= 32 chars each) for production
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-another-random-string-32-chars-min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

CLIENT_URL=http://localhost:5173

# Optional — Phase 2
# RESEND_API_KEY=
# GHN_API_KEY=
# GHN_SHOP_ID=

LOW_STOCK_THRESHOLD=5
